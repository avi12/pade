{
  "name": "pade",
  "version": "0.0.1",
  "description": "PADE (Power ADE) — an Agentic Development Environment that wraps your agent CLI in a comprehension-first GUI",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "app": "tauri dev",
    "app:build": "tauri build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint:js": "oxlint && eslint .",
    "lint:css": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "lint": "pnpm lint:js && pnpm lint:css && pnpm lint:rust",
    "test:js": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "pnpm test:js && pnpm test:rust",
    "fallow": "fallow audit --base HEAD"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@xterm/addon-webgl": "0.20.0-beta.287",
    "@xterm/xterm": "6.1.0-beta.288",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tauri-apps/cli": "^2.2.7",
    "eslint": "^10.6.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-svelte": "^3.20.0",
    "fallow": "2.103.0",
    "globals": "^17.7.0",
    "oxlint": "1.72.0",
    "postcss": "^8.5.16",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.14.0",
    "stylelint-config-ccb": "^3.32.0",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.11",
    "vitest": "^4.1.10"
  }
}
