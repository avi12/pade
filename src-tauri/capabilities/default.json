{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core capabilities for the ADE main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "dialog:default",
    "clipboard-manager:allow-read-text",
    "global-shortcut:default"
  ]
}
